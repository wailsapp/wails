			uintptr(unsafe.Pointer(i)),
{{ .Method.VtableCallInputsARM64}}		)
{{- end}}
	default:
		{{ .Method.GetHResultVariable }}, _, _ = i.Vtbl.{{.Method.ProcessedName}}.Call(
			uintptr(unsafe.Pointer(i)),
{{ .Method.VtableCallInputsAMD64}}		)
	}
{{- else}}

	{{ .Method.GetHResultVariable }}, _, _ := i.Vtbl.{{.Method.ProcessedName}}.Call(
