	var {{ .Method.GetHResultVariable }} uintptr
	switch {
	case archIs386:
		{{ .Method.GetHResultVariable }}, _, _ = i.Vtbl.{{.Method.ProcessedName}}.Call(
			uintptr(unsafe.Pointer(i)),
{{ .Method.VtableCallInputs386}}		)
{{- if .Method.NeedsARM64Variant}}
	case archIsARM64:
