import { createSignal, onMount } from 'solid-js'
import {Events} from "@wailsio/runtime";
import {GreetService} from "../bindings/{{js .ModulePath}}";

function App() {
  const [name, setName] = createSignal('');
  const [result, setResult] = createSignal('');
  const [time, setTime] = createSignal('Listening for Time event...');

  const doGreet = () => {
    let localName = name();
    if (!localName) {
      localName = 'anonymous';
    }
    GreetService.Greet(localName).then((resultValue) => {
      setResult(resultValue);
    }).catch((err) => {
      console.log(err);
    });
  }

  onMount(() => {
    Events.On('time', (timeValue) => {
      setTime(timeValue.data);
    });
  });

  return (
    <main className="container">
      <header className="brand">
        <a className="brand-mark" data-wml-openURL="https://wails.io" aria-label="Wails website">
          <img src="/wails.png" className="brand-logo" alt="Wails logo"/>
        </a>
        <a className="brand-badge" data-wml-openURL="https://solidjs.com" aria-label="Solid">
          <img src="/solid.svg" alt="Solid logo"/>
        </a>
      </header>

      <span className="badge">v3</span>

      <h1 className="title"><span className="title-accent">Wails +</span> Solid</h1>
      <p className="subtitle">Build beautiful cross-platform apps with Go and Solid.</p>

      <div className="greet">
        <div className="input-box">
          <svg className="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <input aria-label="input" className="input" value={name()} onInput={(e) => setName(e.target.value)} type="text" placeholder="Enter your name" autoComplete="off"/>
          <button aria-label="greet-btn" className="btn" onClick={doGreet}>Greet
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
        <div aria-label="result" className="result">{result()}</div>
      </div>

      <a className="learn-card" data-wml-openURL="https://wails.io" aria-label="Learn more about Wails">
        <span className="learn-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </span>
        <span className="learn-text">
          <strong>Learn more about Wails</strong>
          <span>Discover the docs, guides, and community.</span>
        </span>
        <svg className="learn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>

      <footer className="footer">
        <span className="footer-time">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span id="time">{time()}</span>
        </span>
        <span className="footer-version"><span className="dot"></span> Wails v3</span>
      </footer>
    </main>
  )
}

export default App
