import {css, html, LitElement} from 'lit'
import {customElement, property} from 'lit/decorators.js'
import {Events} from "@wailsio/runtime";
import {GreetService} from '../bindings/{{js .ModulePath}}';

/**
 * An example element.
 *
 * @slot - This element has a slot
 * @csspart button - The button
 */
@customElement('my-element')
export class MyElement extends LitElement {

    @property()
    result: string = 'Please enter your name below 👇'

    @property()
    time: string = 'Listening for Time event...'

    @property()
    name: string = '';

    constructor() {
        super();
        Events.On('time', (timeValue: { data: string }) => {
            this.time = timeValue.data;
        });
    }


    doGreet() {
        let name = this.name;
        if (!name) {
            name = 'anonymous';
        }
        GreetService.Greet(name).then((resultValue: string) => {
            this.result = resultValue;
        }).catch((err: Error) => {
            console.log(err);
        });
    }

    render() {
        return html`
            <div class="container">
                <div>
                    <a data-wml-openURL="https://wails.io">
                        <img src="/wails.png" class="logo" alt="Wails logo"/>
                    </a>
                    <a data-wml-openURL="https://lit.dev">
                        <img src="/lit.svg" class="logo lit" alt="Lit logo"/>
                    </a>
                </div>
                <slot></slot>
                <div aria-label="result" class="result">${this.result}</div>
                <div class="card">
                    <div class="input-box">
                        <input aria-label="input" class="input" .value=${this.name} @input=${(e: InputEvent) => this.name = (e.target as HTMLInputElement).value} type="text"
                               autocomplete="off"/>
                        <button aria-label="greet-btn" class="btn" @click=${this.doGreet}>Greet</button>
                    </div>
                </div>
                <div class="footer">
                    <div><p>Click on the Wails logo to learn more</p></div>
                    <div><p>${this.time}</p></div>
                </div>
            </div>
        `
    }


    static styles = css`
        /* Tokens (--bg, --surface, --accent, ...) are defined on :root in the
           global stylesheet and inherit across the shadow boundary. */
        :host {
            display: block;
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
            color: var(--text);
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: max(1.5rem, env(safe-area-inset-top)) max(1.25rem, env(safe-area-inset-right))
                     max(1.5rem, env(safe-area-inset-bottom)) max(1.25rem, env(safe-area-inset-left));
        }

        ::slotted(h1) {
            font-size: clamp(1.9rem, 8vw, 3rem);
            line-height: 1.1;
            font-weight: 700;
            margin: 0.4em 0 0.9em;
        }

        .logo {
            height: clamp(4rem, 16vw, 6rem);
            max-width: 40vw;
            padding: 0.75rem;
            object-fit: contain;
            transition: filter 0.2s ease, transform 0.2s ease;
        }
        .logo:hover {
            filter: drop-shadow(0 0 1.2em var(--accent));
            transform: translateY(-2px);
        }

        .result {
            color: var(--muted);
            font-size: 14px;
            line-height: 1.4;
            margin: 0 0 14px;
            min-height: 20px;
        }

        /* No frame around the input — it fills itself and sits on the page. */
        .card { width: 100%; }
        .input-box { display: flex; gap: 8px; }

        .input {
            flex: 1;
            min-width: 0;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 12px 14px;
            border-radius: var(--radius);
            font-size: 16px;
            outline: none;
        }
        .input:focus {
            outline: 2px solid var(--accent-2);
            border-color: transparent;
        }

        .btn {
            flex: 0 0 auto;
            border: none;
            background: var(--accent);
            color: #fff;
            padding: 12px 18px;
            border-radius: var(--radius);
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s ease, transform 0.1s ease;
        }
        .btn:hover { opacity: 0.92; }
        .btn:active { transform: scale(0.97); }

        .footer {
            margin-top: 22px;
            color: var(--muted);
            font-size: 13px;
        }
        .footer p { margin: 6px 0; }

        a {
            color: var(--accent-2);
            font-weight: 500;
            text-decoration: none;
        }
        a:hover { text-decoration: underline; }
  `;
}

declare global {
    interface HTMLElementTagNameMap {
        'my-element': MyElement
    }
}
